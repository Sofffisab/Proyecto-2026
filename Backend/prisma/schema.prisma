generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  password     String
  username     String   @unique
  photo        Bytes?
  pushToken    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  points       Int @default(0)
  goalDistance Int @default(0)

  qrs          QRS[]
  attendance   Attendance[]
  userData     UserData?
}

model UserData {

  id      Int     @id @default(autoincrement())
  userId  Int     @unique

  // Personal form fields
  age     Int?
  weight  Float?
  height  Float?
  gender  Gender?
  goal    Goal?

  type    String?
  change  String?

  socialization    Boolean @default(true)
  requiresTrainer  Boolean @default(true)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum Goal {
  LOSE_WEIGHT
  BUILD_MUSCLE
  MAINTAIN
  TONE
}

model Machine {
  id   Int    @id @default(autoincrement())
  name String

  qrs  QRS[]
}

model QRS {
  id        Int      @id @default(autoincrement())
  qr        Bytes
  userId    Int?
  machineId Int?

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  machine   Machine? @relation(fields: [machineId], references: [id], onDelete: SetNull)
}

model Attendance {
  id           Int       @id @default(autoincrement())
  userId       Int
  date         DateTime  @db.Date
  checkInTime  DateTime  @db.Time
  checkOutTime DateTime? @db.Time

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}